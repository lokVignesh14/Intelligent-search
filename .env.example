# ---------------------------------------------------------------------------
# Database (required for auto_pricing)
# ---------------------------------------------------------------------------
DB_HOST=localhost
DB_PORT=5432
DB_NAME=your_db
DB_USER=your_user
DB_PASSWORD=your_password

# ---------------------------------------------------------------------------
# Live competitor prices (real-time / day-to-day from any website or API)
# ---------------------------------------------------------------------------
# URL of an API that returns competitor prices. Use {hotel_id} in the URL.
# Example: https://your-api.com/prices?hotel={hotel_id}
# API should return JSON with one of: "avg", "average", "competitorAvg", or "prices" (list).
COMPETITOR_PRICES_API_URL=

# Optional API key for the above URL (sent as X-API-Key header).
COMPETITOR_PRICES_API_KEY=

# Request timeout in seconds for competitor API calls.
COMPETITOR_PRICES_TIMEOUT=10

# SerpAPI key for Google Hotels real-time prices (recommended for Competitor Price column).
# Free tier: https://serpapi.com - enables engine=google_hotels with structured prices.
SERPAPI_KEY=

# Country and currency for Google Hotels (e.g. us, pk, in and USD, PKR, INR).
COMPETITOR_GL=us
COMPETITOR_CURRENCY=USD
